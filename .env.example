# =============================================================================
# Sen2Nal Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sen2nal_user:sen2nal_password@localhost:5432/sen2nal
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sen2nal
DB_USER=sen2nal_user
DB_PASSWORD=sen2nal_password

# -----------------------------------------------------------------------------
# AWS Configuration (for production)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=sen2nal-data-123456789

# -----------------------------------------------------------------------------
# API Keys - Data Sources
# -----------------------------------------------------------------------------
# Alpha Vantage (Free tier: 5 calls/min, 100 calls/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# NewsAPI (Free tier: 100 requests/day)
NEWSAPI_API_KEY=your_newsapi_key_here

# Reddit (PRAW) - Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=Sen2Nal/1.0

# -----------------------------------------------------------------------------
# LLM API Keys (for experiment)
# -----------------------------------------------------------------------------
# OpenAI (ChatGPT)
OPENAI_API_KEY=your_openai_key_here

# Google (Gemini)
GOOGLE_API_KEY=your_google_key_here

# xAI (Grok)
XAI_API_KEY=your_xai_key_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
ENVIRONMENT=development  # development | production
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
ENABLE_CORS=true

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true  # Auto-reload on code changes (dev only)

# Streamlit
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Scheduler Configuration
# -----------------------------------------------------------------------------
# Daily pipeline schedule (cron format: minute hour day month day_of_week)
PIPELINE_SCHEDULE_CRON=0 6 * * *  # 6:00 AM EST daily
ENABLE_SCHEDULER=false  # Set to true to enable automatic scheduling

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_BATCH_SIZE=16
FINBERT_MAX_LENGTH=512

# Signal Combination Weights
NLP_WEIGHT=0.6
CALENDAR_WEIGHT=0.4
CONFLICT_THRESHOLD=0.30

# Calendar Pattern Lookback
CALENDAR_LOOKBACK_MONTHS=18

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_RATE_LIMIT=5  # requests per minute
NEWSAPI_RATE_LIMIT=100  # requests per day
REDDIT_RATE_LIMIT=60  # requests per minute

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
SECRET_KEY=your_secret_key_for_sessions_here_change_in_production
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_EXPERIMENT_TRACKING=true
ENABLE_BACKTEST=false  # KIV for Phase 4
ENABLE_MODEL_RETRAINING=false  # KIV for Phase 4
